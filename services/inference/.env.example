MODAL_SCALEDOWN_WINDOW=0
MODEL_N_CTX=2048
MODEL_MAX_TOKENS=256
MODEL_TEMPERATURE=0.4
MODEL_TOP_P=0.9
MODEL_REPEAT_PENALTY=1.1
MODEL_N_THREADS=4
MODEL_N_GPU_LAYERS=0
