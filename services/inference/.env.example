# Copy these values into a local .env file or a Modal Secret before deployment.

INFERENCE_AUTH_TOKEN=replace-me
MODEL_ALIAS=alan-llm-jeju-dialect-v1-4b-q4km
MODEL_PATH=
MODEL_FILENAME=alan-llm-jeju-dialect-v1-4b-q4km.gguf
MODEL_VOLUME_NAME=jejueo-translator-models
MODEL_VOLUME_MOUNT_PATH=/models
MODAL_APP_NAME=jejueo-translator-inference
MODAL_SECRET_NAME=jejueo-translator-inference
